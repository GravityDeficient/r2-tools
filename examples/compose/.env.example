# Rename to .env and `chmod 600 .env` before use. Never commit this file.

R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Optional:
# R2_SYNC_DRYRUN=1   # preview the rclone command without transferring
